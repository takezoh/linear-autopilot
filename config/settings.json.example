{
  "team": "",
  "budget": {
    "poll": "0.10",
    "planning": "3.00",
    "implementing": "5.00",
    "plan_review": "3.00",
    "review": "3.00",
    "subissue_creation": "5.00"
  },
  "max_turns": {
    "planning": 30,
    "implementing": 50,
    "plan_review": 30,
    "review": 30,
    "subissue_creation": 15
  },
  "model": {
    "default": "sonnet",
    "planning": "sonnet",
    "implementing": "sonnet",
    "plan_review": "sonnet",
    "pr": "haiku",
    "review": "opus",
    "subissue_creation": "sonnet"
  },
  "log_dir": "/path/to/logs",
  "lock_dir": "/path/to/lock",
  "worktree_dir": "/path/to/worktrees",
  "max_concurrent": 5,
  "lock_timeout_min": 60,
  "webhook": { "host": "0.0.0.0", "port": 3000 },
  "allowed_tools": {
    "implementing": ["Edit", "Write", "Glob", "Grep", "Read", "Bash"]
  },
  "claude": {
    "sandbox": {
      "enabled": true,
      "autoAllowBashIfSandboxed": true,
      "allowUnsandboxedCommands": false,
      "filesystem": {
        "denyRead": [
          "~"
        ],
        "denyWrite": [
          "~"
        ]
      },
      "network": {
        "allowManagedDomainsOnly": true,
        "allowedDomains": [
          "api.linear.app",
          "github.com",
          "*.github.com",
          "*.githubusercontent.com",
          "api.anthropic.com"
        ]
      }
    }
  }
}